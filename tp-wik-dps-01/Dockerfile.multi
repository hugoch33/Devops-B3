FROM golang:1.21-alpine AS builder

WORKDIR /src

COPY go.mod ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/ping-server .

FROM alpine:3.20

RUN addgroup -S appgroup && adduser -S appuser -G appgroup

WORKDIR /home/appuser

COPY --from=builder /out/ping-server /usr/local/bin/ping-server

ENV PING_LISTEN_PORT=8080
EXPOSE 8080

USER appuser

ENTRYPOINT ["/usr/local/bin/ping-server"]
